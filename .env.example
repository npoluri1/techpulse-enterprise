# ============================================================
# TechPulse Daily - Configuration
# ============================================================
# Copy this to .env and fill in your values

# Enterprise API Keys (FREE tiers available)
GEMINI_API_KEY=your_gemini_api_key_here       # Google AI Studio (free 1500/day)
NEWSAPI_KEY=your_newsapi_key_here              # NewsAPI.org (free 100/day)
SERPER_API_KEY=your_serper_key_here            # Serper.dev (free 2500/month)

# Optional: OpenAI API Key (for AI-powered curation)
OPENAI_API_KEY=sk-xxx

# Email Configuration (SMTP)
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=recipient_email@gmail.com
EMAIL_PASSWORD=your_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# WhatsApp Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_WHATSAPP_NUMBER=+14155238886
WHATSAPP_PHONE_NUMBER=+1234567890

# Schedule (24h format)
SCHEDULE_HOUR=08
SCHEDULE_MINUTE=00

# Optional: Firecrawl for web scraping
FIRECRAWL_API_KEY=fc-xxx
